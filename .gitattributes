# ─── Default: auto-detect text; normalise to LF on checkout ──────────────────
* text=auto eol=lf

# ─── Web source files (always LF — matches Prettier endOfLine: "lf") ─────────
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.xml  text eol=lf
*.svg  text eol=lf

# ─── Binary assets (no line-ending conversion) ────────────────────────────────
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.mp4    binary
*.webm   binary
*.ogg    binary
*.ttf    binary
*.woff   binary
*.woff2  binary
*.eot    binary
*.otf    binary
*.pdf    binary
